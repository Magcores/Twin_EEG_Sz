# ──────────────────────────────────────────
# Large EEG / neuroimaging data files
# ──────────────────────────────────────────
*.fif
*.edf
*.stc
*.h5
*.npy
*.npz

# ──────────────────────────────────────────
# Pipeline output files
# (keep root-level tracked outputs explicitly below)
# ──────────────────────────────────────────
Preprocessed/Continuous/*
Preprocessed/Epoched/*
Preprocessed/Plots/*/
Preprocessed/Source/*/
Preprocessed/Connectivity_wPLI_bands/*/
Preprocessed/PowerAndFoooF/*
Preprocessed/Features/*.csv
Preprocessed/Features/*.txt
Raw_edf/*
Raws/*
Outputs ML/**/*.csv
Outputs ML/**/*.png
Outputs ML/**/*.json

# fs_templates: un-ignore the directory (blocked by Source/*/), then re-ignore
# its contents (large brain files), and let !**/.gitkeep rescue the marker below
!Preprocessed/Source/fs_templates/
Preprocessed/Source/fs_templates/*

# Keep .gitkeep files everywhere
!**/.gitkeep

# Root-level ML output files (generated by 6_ML_Final.py)
Diff_Top_Feature_Contributions.csv
Diff_PCA_Detailed_Contributions.json

